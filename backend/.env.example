# Frontend URL (for payment redirect after payment success)
# Development: http://localhost:5174
# Production: https://your-frontend-domain.com
FRONTEND_URL=http://localhost:5174

# Backend URL (for payment callback)
# Development: http://localhost:5003
# Production: https://doctors-farms-backend.up.railway.app
BACKEND_URL=http://localhost:5003

# Backend mail settings
# MAIL_PROVIDER options: custom | gmail | brevo | resend
MAIL_PROVIDER=custom
# Optional sender identity shown to recipients
MAIL_FROM=your-email@example.com

# Required when MAIL_PROVIDER=resend
RESEND_API_KEY=your_resend_api_key

# SMTP host/port/secure can be omitted when MAIL_PROVIDER=gmail or MAIL_PROVIDER=brevo
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
CONTACT_EMAIL=doctorsfarms686@gmail.com
ADMIN_LIST=doctorsfarms686@gmail.com,admin2@example.com

# PhonePe Payment Gateway settings
PHONEPE_MERCHANT_ID=YOUR_MERCHANT_ID
PHONEPE_SALT_KEY=YOUR_SALT_KEY
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=sandbox

# Railway Deployment (auto-set by platform, no need to configure manually)
# RAILWAY_PUBLIC_DOMAIN=your-app.railway.app