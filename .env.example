# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES (.env.local for development)
# =============================================================================
# Vite will use VITE_ prefix to expose variables to client-side code

# API Base URL - points to backend server
# Local development:       http://localhost:5174
# Remote server by IP:     http://192.168.x.x:5174
# Deployed backend:        https://doctors-farms-backend.up.railway.app
# Production domain:       https://api.doctorsfarms.com
VITE_API_URL=http://localhost:5174

# =============================================================================
# BACKEND ENVIRONMENT VARIABLES (backend/.env)
# =============================================================================

# Node.js Environment
NODE_ENV=development

# Server Configuration
PORT=5174
HOST=localhost

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:5173

# Backend URL (for doctor's farms backend reference)
BACKEND_URL=http://localhost:5174

# =============================================================================
# EMAIL SERVICE (Resend)
# =============================================================================

# Mail Provider - use 'resend' for Resend service
MAIL_PROVIDER=resend

# Resend API Key - get from https://resend.com/api-tokens
# ⚠️ SECURITY: Never commit this to version control; use Railway secrets in production
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender email address
# Production: Must be a verified domain (e.g., bookings@doctorsfarms.in)
# Development: Can be any test email with Resend
MAIL_FROM=bookings@doctorsfarms.in

# Contact email address (for form submissions)
CONTACT_EMAIL=doctorsfarms686@gmail.com

# Admin email list (comma-separated for multiple admins)
# Inquiries will be sent to all emails in this list
ADMIN_LIST=doctorsfarms686@gmail.com,admin2@example.com

# =============================================================================
# PRODUCTION DEPLOYMENT (Railway)
# =============================================================================
# For production on Railway, update the following:
# NODE_ENV=production
# PORT=5000 (Railway assigns this)
# HOST=0.0.0.0
# FRONTEND_URL=https://doctors-farms.up.railway.app
# BACKEND_URL=https://doctors-farms-backend.up.railway.app
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx (rotated key)
# MAIL_FROM=bookings@doctorsfarms.in (verified domain)
# ADMIN_LIST=your-admin@gmail.com,second-admin@gmail.com
