# API Configuration
# For development: Leave empty or set to http://localhost:5003
# For production: Set to your deployment domain, e.g., https://api.doctorsfarms.com or http://your-server-ip:5003
# VITE_API_URL=http://localhost:5003

# Example configurations:
# Local development:
#   VITE_API_URL=http://localhost:5003
#
# Remote server by IP:
#   VITE_API_URL=http://192.168.x.x:5003
#
# Production domain:
#   VITE_API_URL=https://api.doctorsfarms.com
